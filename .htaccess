Options -Indexes
RewriteEngine On

# Blokuj přímý přístup ke config_secret.php
<Files "config_secret.php">
    Order Allow,Deny
    Deny from all
</Files>

# Existující soubory a složky servíruj přímo
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# API endpointy — přepiš na PHP soubory
RewriteRule ^api/(.+)$ api/$1.php [L]

# Vše ostatní → index.html (SPA routing)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L,QSA]